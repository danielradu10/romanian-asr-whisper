*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment / secrets
.env
.env.*
*.env

# Jupyter / notebooks
.ipynb_checkpoints/

# OS / IDE
.DS_Store
.idea/
.vscode/

# Raw data
data/raw/

# Processed/generated data
data/processed/*
!data/processed/.gitkeep
!data/processed/README.md

# Audio files
*.wav
*.mp3
*.flac
*.m4a
*.ogg

# Embeddings / numpy / serialized artifacts
*.npy
*.npz
*.pkl
*.pickle
